{
  "schemaVersion": 1,
  "id": "securetrade",
  "version": "${version}",
  "name": "Secure Trade",
  "description": "Trade items and XP with other players from anywhere, across distance and dimensions, with configurable server-side limits.",
  "authors": [
    "Navielon"
  ],
  "contact": {
    "homepage": "https://github.com/Navielon/SecureTrade",
    "sources": "https://github.com/Navielon/SecureTrade",
    "issues": "https://github.com/Navielon/SecureTrade/issues"
  },
  "license": "MIT",
  "icon": "mod_icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.securetrade.FabricSecureTradeMod"
    ],
    "client": [
      "com.securetrade.FabricClientInitializer"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": ">=26.2 <26.3",
    "java": ">=25",
    "fabric-api": "*"
  }
}
